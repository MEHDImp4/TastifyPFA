# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (MySQL)
DB_ENGINE=django.db.backends.mysql
DB_NAME=tastify_db
DB_USER=tastify_user
DB_PASSWORD=your-db-password
DB_HOST=db
DB_PORT=3306

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# NLP — optional. Enables HuggingFace Inference API as primary sentiment engine.
# If absent, the local TF-IDF + LinearSVC fallback is used automatically.
HUGGINGFACE_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
