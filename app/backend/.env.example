# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_BASE_URL=http://localhost:3003
PASSWORD_RESET_TIMEOUT=3600

# Database (MySQL)
DB_ENGINE=django.db.backends.mysql
DB_NAME=tastify_db
DB_USER=tastify_user
DB_PASSWORD=your-db-password
DB_HOST=db
DB_PORT=3306

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Transactional email
DEFAULT_FROM_EMAIL=no-reply@tastify.local
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False

# NLP — optional. Enables HuggingFace Inference API as primary sentiment engine.
# If absent, the local multilingual fallback is used automatically.
HUGGINGFACE_API_TOKEN=
