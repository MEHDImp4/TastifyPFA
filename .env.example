# ── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_SETTINGS_MODULE=tastify_backend.settings.dev
FRONTEND_BASE_URL=http://localhost:3003

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_DATABASE=tastify_db
MYSQL_USER=tastify_user
MYSQL_PASSWORD=tastify_pass
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_HOST=db
MYSQL_PORT=3306

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=django-db
CELERY_CACHE_BACKEND=django-cache

# ── Frontend build-time config ───────────────────────────────────────────────
VITE_API_BASE_URL=/api
VITE_MEDIA_BASE_URL=https://tastify-api.mehdidiouri.dev
VITE_WS_BASE_URL=
VITE_STAFF_WS_PATH=/ws/staff/

# NLP — optional. If provided, HuggingFace is used first for sentiment analysis.
# If empty, Tastify falls back to its local multilingual sentiment analyzer.
HUGGINGFACE_API_TOKEN=
