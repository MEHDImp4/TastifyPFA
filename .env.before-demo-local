# Copy this file to .env on your Unraid Compose Manager project, then replace secrets.
# If you deploy from the CLI instead, you can name it .env.unraid and pass
# --env-file .env.unraid to docker compose.

# Django
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
DJANGO_SETTINGS_MODULE=tastify_backend.settings.prod
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,UNRAID_IP,tastify-back.mehdidiouri.dev,tastify-api.mehdidiouri.dev,tastify-staff.mehdidiouri.dev,tastify-client.mehdidiouri.dev
CORS_ALLOWED_ORIGINS=http://UNRAID_IP:3000,http://UNRAID_IP:3003,https://tastify-back.mehdidiouri.dev,https://tastify-api.mehdidiouri.dev,https://tastify-staff.mehdidiouri.dev,https://tastify-client.mehdidiouri.dev
CSRF_TRUSTED_ORIGINS=http://UNRAID_IP:3000,http://UNRAID_IP:3003,https://tastify-back.mehdidiouri.dev,https://tastify-api.mehdidiouri.dev,https://tastify-staff.mehdidiouri.dev,https://tastify-client.mehdidiouri.dev
FRONTEND_BASE_URL=https://tastify-client.mehdidiouri.dev

# Frontend build-time config for the three-domain deployment:
# client frontend, staff frontend, and public API backend.
VITE_API_BASE_URL=https://tastify-back.mehdidiouri.dev/api
VITE_MEDIA_BASE_URL=https://tastify-back.mehdidiouri.dev
VITE_WS_BASE_URL=https://tastify-back.mehdidiouri.dev
VITE_STAFF_WS_PATH=/ws/staff/

# Keep these False for direct LAN HTTP. Change to True when serving through HTTPS.
DJANGO_COOKIE_SECURE=False
DJANGO_SECURE_SSL_REDIRECT=False

# MySQL
MYSQL_DATABASE=tastify_db
MYSQL_USER=tastify_user
MYSQL_PASSWORD=replace-with-a-strong-password
MYSQL_ROOT_PASSWORD=replace-with-a-strong-root-password
MYSQL_HOST=db
MYSQL_PORT=3306

# Redis / Celery
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=django-db
CELERY_CACHE_BACKEND=django-cache

# Public ports on Unraid
BACKEND_PORT=8000
BACKOFFICE_PORT=3000
CLIENT_PORT=3003

# GHCR images. Replace YOUR_GITHUB_OWNER with your GitHub username or organization,
# lowercased. Use :latest for main/master or :sha-<commit> for a pinned deploy.
BACKEND_IMAGE=ghcr.io/YOUR_GITHUB_OWNER/tastifypfa-backend:latest
BACKOFFICE_IMAGE=ghcr.io/YOUR_GITHUB_OWNER/tastifypfa-backoffice:latest
CLIENT_IMAGE=ghcr.io/YOUR_GITHUB_OWNER/tastifypfa-client:latest

# Set to 1 only if you want demo data on the first boot.
SEED_ON_STARTUP=0
